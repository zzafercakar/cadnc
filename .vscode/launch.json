{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Linux) Launch CADNC",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/cadnc",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "DISPLAY", "value": ":0" },
                { "name": "QT_QPA_PLATFORM", "value": "xcb" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build"
        }
    ]
}
